{
  "name": "spotify-ptt-bridge",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Local Spotify OAuth control plus push-to-talk mic bridge for OpenClaw.",
  "scripts": {
    "start": "node server.mjs",
    "dev": "node server.mjs --open",
    "check": "node --check server.mjs && node --check ptt/hotkey-toggle.mjs",
    "ptt:toggle": "node ptt/hotkey-toggle.mjs toggle",
    "ptt:start": "node ptt/hotkey-toggle.mjs start",
    "ptt:stop": "node ptt/hotkey-toggle.mjs stop",
    "ptt:x11": "python ptt/x11-ptt-listener.py",
    "ptt:raw": "python ptt/raw-ptt-listener.py"
  }
}
