{
  "server": {
    "port": 8787
  },
  "spotify": {
    "clientId": "YOUR_SPOTIFY_CLIENT_ID",
    "redirectUri": "http://127.0.0.1:8787/callback",
    "scopes": [
      "user-read-playback-state",
      "user-modify-playback-state",
      "playlist-read-private",
      "playlist-read-collaborative"
    ],
    "playlists": {
      "chill": "spotify:playlist:YOUR_PLAYLIST_ID",
      "gym": {
        "uri": "spotify:playlist:YOUR_PLAYLIST_ID",
        "name": "Gym"
      }
    }
  },
  "openclaw": {
    "agentId": "",
    "sessionId": "YOUR_OPENCLAW_SESSION_ID",
    "thinking": "medium",
    "deliver": true,
    "replyChannel": "discord",
    "replyAccountId": "YOUR_OPENCLAW_ACCOUNT_ID",
    "replyTo": "YOUR_DISCORD_CHANNEL_ID",
    "profiles": {
      "hermy-tv": {
        "agentId": "twitch",
        "sessionId": "YOUR_HERMY_TV_VOICE_SESSION_ID",
        "thinking": "medium",
        "deliver": false
      }
    }
  },
  "output": {
    "reactionFile": "../streamlabels-hermy-bridge/output/hermy_reaction.txt",
    "clearAfterMs": 15000
  },
  "transcription": {
    "model": "",
    "language": "en"
  },
  "recorder": {
    "cmd": "pw-record",
    "device": "",
    "rate": 16000,
    "channels": 1,
    "format": "s16"
  },
  "clip": {
    "enabled": true,
    "script": "./ptt/clip-replay.sh"
  }
}
